DATABASE_URL=postgres://postgres:postgres@localhost:5432/edu?sslmode=disable
PORT=8080

# Keycloak — JWKS URL реалма, в котором созданы пользователи.
# Реалм `edu` импортируется из keycloak/realm-edu.json при старте контейнера.
KEYCLOAK_JWKS_URL=http://localhost:8180/realms/edu/protocol/openid-connect/certs

# Тестовый публичный клиент для получения токена (Direct Access Grant):
#   client_id=edu-frontend
# Тестовые пользователи (пароль у всех `password`), группа уезжает в токен
# как Keycloak-claim `groups`:
#   student1  -> student,     группа BSE-2024
#   student2  -> student,     группа BSE-2023
#   admin1    -> group_admin, группа BSE-2024 (куратор BSE-2024)
#   root      -> super_admin, без группы (видит все)
# Получить токен:
#   curl -s -d client_id=edu-frontend -d username=student1 -d password=password \
#        -d grant_type=password \
#        http://localhost:8180/realms/edu/protocol/openid-connect/token | jq -r .access_token

# MinIO / S3
# NB: presigned URL'ы выдаются на этот endpoint. Он должен быть доступен из браузера.
# В docker-compose backend ходит на minio:9000, а браузеру нужен localhost:9000 —
# для реальной прямой загрузки задайте host-доступный endpoint (см. design-doc, п.4 CORS).
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=edu-files
S3_USE_SSL=false
