{
    "swagger": "2.0",
    "info": {
        "description": "Учёт студенческих активностей. Аутентификация — через Keycloak (Bearer JWT); пользователи/группы живут в Keycloak, не в этом сервисе.",
        "title": "Edu Platform API",
        "contact": {},
        "version": "1.0"
    },
    "basePath": "/",
    "paths": {
        "/activities": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "group_admin sees only their own group; super_admin may filter by ?group.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "admin"
                ],
                "summary": "Admin activity feed (group-scoped)",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Group (super_admin only)",
                        "name": "group",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Filter by status",
                        "name": "status",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Filter by category",
                        "name": "category",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Filter by Keycloak student id",
                        "name": "student_id",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/edu-platform_internal_domain.Activity"
                            }
                        }
                    }
                }
            }
        },
        "/activities/my": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "activities"
                ],
                "summary": "List my activities",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Filter by status",
                        "name": "status",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Filter by category",
                        "name": "category",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/edu-platform_internal_domain.Activity"
                            }
                        }
                    }
                }
            }
        },
        "/activities/upload-url": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Creates a PENDING activity (group snapshotted from the token) and returns a presigned PUT URL. The browser uploads the PDF directly to S3, then calls confirm.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "activities"
                ],
                "summary": "Create activity and get a presigned PDF upload URL",
                "parameters": [
                    {
                        "description": "Activity metadata",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_handlers.uploadURLRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/internal_handlers.uploadURLResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/internal_handlers.errorResponse"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/internal_handlers.errorResponse"
                        }
                    }
                }
            }
        },
        "/activities/{id}": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "activities"
                ],
                "summary": "Get activity details",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Activity id",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/edu-platform_internal_domain.Activity"
                        }
                    },
                    "403": {
                        "description": "Forbidden",
                        "schema": {
                            "$ref": "#/definitions/internal_handlers.errorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/internal_handlers.errorResponse"
                        }
                    }
                }
            }
        },
        "/activities/{id}/confirm": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Verifies the object exists in S3 (HEAD) and moves the activity from PENDING to SUBMITTED.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "activities"
                ],
                "summary": "Confirm a finished PDF upload",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Activity id",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/edu-platform_internal_domain.Activity"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/internal_handlers.errorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/internal_handlers.errorResponse"
                        }
                    }
                }
            }
        },
        "/activities/{id}/evaluation": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Awards points/credits (status EVALUATED) or rejects with a comment (status REJECTED). group_admin is restricted to their own group.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "evaluation"
                ],
                "summary": "Evaluate or reject an activity",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Activity id",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Evaluation",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_handlers.evaluationRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/edu-platform_internal_domain.Evaluation"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/internal_handlers.errorResponse"
                        }
                    },
                    "403": {
                        "description": "Forbidden",
                        "schema": {
                            "$ref": "#/definitions/internal_handlers.errorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/internal_handlers.errorResponse"
                        }
                    }
                }
            }
        },
        "/activities/{id}/file": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Returns a short-lived presigned GET URL. The browser fetches the PDF directly from S3.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "activities"
                ],
                "summary": "Get a presigned URL to view/download the activity PDF",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Activity id",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/internal_handlers.fileURLResponse"
                        }
                    },
                    "403": {
                        "description": "Forbidden",
                        "schema": {
                            "$ref": "#/definitions/internal_handlers.errorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/internal_handlers.errorResponse"
                        }
                    }
                }
            }
        },
        "/dashboard/me": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "dashboard"
                ],
                "summary": "Personal dashboard aggregates",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/edu-platform_internal_domain.DashboardMe"
                        }
                    }
                }
            }
        },
        "/dashboard/summary": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "admin"
                ],
                "summary": "Aggregate stats per student (group-scoped)",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Group (super_admin only)",
                        "name": "group",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Filter by category",
                        "name": "category",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Filter by Keycloak student id",
                        "name": "student_id",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/edu-platform_internal_domain.StudentStats"
                            }
                        }
                    }
                }
            }
        },
        "/export/me": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "produces": [
                    "text/csv"
                ],
                "tags": [
                    "dashboard"
                ],
                "summary": "Export my activities as CSV",
                "responses": {
                    "200": {
                        "description": "CSV",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/export/summary": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "produces": [
                    "text/csv"
                ],
                "tags": [
                    "admin"
                ],
                "summary": "Export the admin summary as CSV",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Group (super_admin only)",
                        "name": "group",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Filter by category",
                        "name": "category",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "CSV",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "edu-platform_internal_domain.Activity": {
            "type": "object",
            "properties": {
                "category": {
                    "type": "string"
                },
                "created_at": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "evaluation": {
                    "$ref": "#/definitions/edu-platform_internal_domain.Evaluation"
                },
                "id": {
                    "type": "integer"
                },
                "status": {
                    "type": "string"
                },
                "student_group": {
                    "description": "snapshot",
                    "type": "string"
                },
                "student_id": {
                    "description": "Keycloak sub",
                    "type": "string"
                },
                "title": {
                    "type": "string"
                }
            }
        },
        "edu-platform_internal_domain.DashboardMe": {
            "type": "object",
            "properties": {
                "activity_count": {
                    "type": "integer"
                },
                "by_category": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "integer"
                    }
                },
                "by_status": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "integer"
                    }
                },
                "total_credits": {
                    "type": "number"
                },
                "total_points": {
                    "type": "integer"
                }
            }
        },
        "edu-platform_internal_domain.Evaluation": {
            "type": "object",
            "properties": {
                "activity_id": {
                    "type": "integer"
                },
                "admin_id": {
                    "description": "Keycloak sub of the evaluator",
                    "type": "string"
                },
                "comment": {
                    "type": "string"
                },
                "credits": {
                    "type": "number"
                },
                "evaluated_at": {
                    "type": "string"
                },
                "id": {
                    "type": "integer"
                },
                "points": {
                    "type": "integer"
                }
            }
        },
        "edu-platform_internal_domain.StudentStats": {
            "type": "object",
            "properties": {
                "activity_count": {
                    "type": "integer"
                },
                "evaluated_count": {
                    "type": "integer"
                },
                "student_group": {
                    "type": "string"
                },
                "student_id": {
                    "type": "string"
                },
                "total_credits": {
                    "type": "number"
                },
                "total_points": {
                    "type": "integer"
                }
            }
        },
        "internal_handlers.errorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string"
                }
            }
        },
        "internal_handlers.evaluationRequest": {
            "type": "object",
            "properties": {
                "comment": {
                    "type": "string"
                },
                "credits": {
                    "description": "optional; defaults from points",
                    "type": "number"
                },
                "points": {
                    "type": "integer"
                },
                "reject": {
                    "type": "boolean"
                }
            }
        },
        "internal_handlers.fileURLResponse": {
            "type": "object",
            "properties": {
                "file_url": {
                    "type": "string"
                }
            }
        },
        "internal_handlers.uploadURLRequest": {
            "type": "object",
            "properties": {
                "category": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "title": {
                    "type": "string"
                }
            }
        },
        "internal_handlers.uploadURLResponse": {
            "type": "object",
            "properties": {
                "activity_id": {
                    "type": "integer"
                },
                "pdf_key": {
                    "type": "string"
                },
                "upload_url": {
                    "type": "string"
                }
            }
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "description": "Введите \"Bearer {token}\", где token — access token из Keycloak.",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}